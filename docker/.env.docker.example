# ============================================
# MonoMERN - Docker Environment Configuration
# ============================================
# Copy this file to .env.docker and fill in your values:
#   cp .env.docker.example .env.docker
#
# The deploy script does this automatically.
# ============================================

# ----- Application -----
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ----- Domain (for SSL / Certbot) -----
DOMAIN=example.com

# ----- Security -----
TRUST_PROXY=1
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CORS_ORIGINS=https://example.com
CSRF_COOKIE_SECURE=true
SESSION_SECRET=CHANGE_ME_RANDOM_SECRET

# ----- Database -----
# Docker Compose connects to the mongo service automatically.
# For MongoDB Atlas, replace with your atlas URI.
DB_LOCAL_URI=mongodb://mongo:27017/monomern
DB_ATLAS_URI=

# ----- Email (OTP) -----
OTP_EMAIL=
OTP_EMAIL_PASSWORD=
OTP_EMAIL_SERVICE=gmail

# ----- JWT -----
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET
JWT_EXPIRATION=1h

# ----- Social Auth (optional) -----

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
